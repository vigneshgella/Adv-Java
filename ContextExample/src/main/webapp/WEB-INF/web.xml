<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd" id="WebApp_ID" version="3.1">
  <servlet>
  		<servlet-name>RCB</servlet-name>
  		<servlet-class>com.context.FirstServlet</servlet-class>	
  </servlet>
  <servlet-mapping>
  		<servlet-name>RCB</servlet-name>
  		<url-pattern>/rcb</url-pattern>
  </servlet-mapping>
  
  
  <servlet>
  		<servlet-name>CSK</servlet-name>
  		<servlet-class>com.context.SecondServlet</servlet-class>	
  </servlet>
  <servlet-mapping>
  		<servlet-name>CSK</servlet-name>
  		<url-pattern>/csk</url-pattern>
  </servlet-mapping>
  
  
  <context-param>
  	<param-name>driver</param-name>
  	<param-value>com.mysql.cj.jdbc.Driver</param-value>
  </context-param>
  <context-param>
  	<param-name>url</param-name>
  	<param-value>jdbc:mysql://localhost:3306/test</param-value>
  </context-param>
  
  
  
</web-app>